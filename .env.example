# --- مسیرها ---
# محل ذخیره‌ی سشِن هر اکانت (بعد از لاگین اول)
SESSIONS_DIR=./sessions
# محل فایل/عکس‌هایی که می‌خوای بفرستی
MEDIA_DIR=./media

# --- ایتاوب ---
EITAA_WEB_URL=https://web.eitaa.com

# مرورگر بدون نمایش گرافیکی اجرا بشه؟
# برای لاگینِ بارِ اول بذار false تا مرورگر رو ببینی و کد رو بزنی.
# روی سرور بعد از لاگین می‌تونی true کنی.
HEADLESS=false

# اگر مرورگر پلی‌رایت دانلود نشد (سرور به CDN دسترسی نداشت)،
# chromium سیستمی را با apt نصب کن و مسیرش را اینجا بذار:
#   apt install -y chromium         → معمولاً /usr/bin/chromium
#   apt install -y chromium-browser → معمولاً /usr/bin/chromium-browser
# BROWSER_EXECUTABLE_PATH=/usr/bin/chromium

# آرگومان‌های مرورگر (--no-sandbox برای اجرا با root لازم است)
# BROWSER_ARGS=--no-sandbox,--disable-dev-shm-usage

# --- رفتار انسانی (ضد بن) ---
# مکث تصادفی بین ارسال به هر مخاطب (ثانیه)
MIN_SEND_DELAY=3
MAX_SEND_DELAY=9

# تایم‌اوت پیش‌فرض عملیات‌ها (میلی‌ثانیه)
DEFAULT_TIMEOUT_MS=30000

# --- لاگ و دیباگ ---
LOG_DIR=./logs
LOG_LEVEL=INFO
# هنگام خطا، اسکرین‌شات و HTML صفحه ذخیره شود (برای دیباگ سلکتورها)
DEBUG_ON_ERROR=true
DEBUG_DIR=./debug
